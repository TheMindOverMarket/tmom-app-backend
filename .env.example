# Backend env for the TMOM app backend

# Core app
ENVIRONMENT=local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tmom_backend
JWT_SECRET=local-secret-key-change-in-prod

# Alpaca paper trading
ALPACA_API_KEY=your_alpaca_paper_key
ALPACA_API_SECRET=your_alpaca_paper_secret

# Optional external services
DEVIATION_ENGINE_BASE_URL=https://your-deviation-engine.onrender.com
RULE_ENGINE_BASE_URL=https://rule-engine-rcg9.onrender.com
